# Database - Supabase PostgreSQL
# Pooled connection (used by the app at runtime, via PgBouncer on port 6543)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (used for migrations, port 5432, no PgBouncer)
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_URL="https://your-production-domain.com"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# Web Push (VAPID) - run: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@your-domain.com"

# Demo reset (DO NOT set to true in production)
# ENABLE_DEMO_RESET=true
