generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PRESIDENT
  FOUNDER_AGENT
  FINANCE
  SECRETARY
  DIRECTOR
  SUPERVISOR
  APPLICANT
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  CLOSED
}

enum RequestType {
  REIMBURSEMENT
  PREPAID
}

enum RequestStatus {
  DRAFT
  WITHDRAWN
  PENDING
  APPROVED
  REJECTED
  RETURNED
  PAID
  PENDING_SETTLEMENT
  OFFSET_SUBMITTED
  OFFSET_RETURNED
  CLOSED
}

enum ApprovalAction {
  APPROVED
  REJECTED
  RETURNED
}

enum AuditAction {
  USER_LOGIN
  REQUEST_CREATED
  REQUEST_UPDATED
  REQUEST_SUBMITTED
  REQUEST_WITHDRAWN
  REQUEST_APPROVED
  REQUEST_RETURNED
  REQUEST_REJECTED
  PAYMENT_MARKED
  SETTLEMENT_SUBMITTED
  SETTLEMENT_RETURNED
  SETTLEMENT_APPROVED
  ATTACHMENT_UPLOADED
  ATTACHMENT_DELETED
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_STATUS_CHANGED
  PROJECT_DELETED
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  PASSWORD_RESET
  DATA_EXPORTED
  ACCOUNTING_SUBJECT_CREATED
  ACCOUNTING_SUBJECT_UPDATED
  ACCOUNTING_SUBJECT_DEACTIVATED
  ACCOUNTING_SUBJECT_CHANGED
  PAYMENT_ADJUSTMENT_CREATED
  PAYMENT_ADJUSTMENT_UPDATED
  PAYMENT_ADJUSTMENT_DELETED
  TRANSACTION_CREATED
  TRANSACTION_UPDATED
  TRANSACTION_DELETED
  FINANCIAL_ACCOUNT_UPDATED
}

enum FinancialAccountType {
  POST_OFFICE
  BANK
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum NotificationType {
  REQUEST_SUBMITTED
  APPROVAL_ASSIGNED
  REQUEST_WITHDRAWN
  REQUEST_APPROVED
  REQUEST_RETURNED
  REQUEST_REJECTED
  PAYMENT_COMPLETED
  REIMBURSEMENT_REQUIRED
  SETTLEMENT_SUBMITTED
  SETTLEMENT_RETURNED
  SETTLEMENT_APPROVED
  REQUEST_CLOSED
  PAYMENT_ADJUSTMENT_ADDED
}

enum PaymentAdjustmentType {
  BANK_FEE
  TRANSFER_FEE
  INTERBANK_FEE
  OTHER
}

model User {
  id           String           @id @default(cuid())
  name         String
  email        String           @unique
  passwordHash String
  role         UserRole         @default(DIRECTOR)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  requests          Request[]
  approvals         ApprovalRecord[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  createdAdjustments PaymentAdjustment[] @relation("PaymentAdjustmentCreatedBy")
  updatedAdjustments PaymentAdjustment[] @relation("PaymentAdjustmentUpdatedBy")
  createdTransactions AccountTransaction[] @relation("TransactionCreatedBy")

  @@map("users")
}

model Project {
  id        String        @id @default(cuid())
  name      String        @unique
  status    ProjectStatus @default(IN_PROGRESS)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  requests     Request[]
  transactions AccountTransaction[]

  @@map("projects")
}

model Request {
  id             String         @id @default(cuid())
  requestNumber  String?        @unique
  type           RequestType
  status         RequestStatus  @default(DRAFT)
  title          String
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id])
  projectName    String?
  description    String?
  purpose        String?
  amount         Decimal        @db.Decimal(12, 2)
  currency       String         @default("TWD")
  requestDate    DateTime       @default(now())
  neededBy       DateTime?
  submittedAt    DateTime?
  paidAt             DateTime?
  paymentMethod      String?
  paymentReference   String?
  paymentNote        String?
  paidBy                 String?
  bankLastFive           String?
  paymentRecipientName   String?
  bankName           String?
  bankCode           String?
  branchName         String?
  branchCode         String?
  bankAccountNumber  String?
  recipientName      String?
  paymentInfoNote    String?
  actualAmount             Decimal?  @db.Decimal(12, 2)
  reimbursementNote        String?
  reimbursementSubmittedAt DateTime?
  offsetReviewedAt         DateTime?
  offsetReviewedBy         String?
  offsetReviewNote         String?
  accountingSubjectId      String?
  accountingSubject        AccountingSubject? @relation("AccountingSubject", fields: [accountingSubjectId], references: [id])
  finalAccountingSubjectId String?
  finalAccountingSubject   AccountingSubject? @relation("FinalAccountingSubject", fields: [finalAccountingSubjectId], references: [id])
  submitterId    String
  submitter      User           @relation(fields: [submitterId], references: [id])
  items          RequestItem[]
  attachments        Attachment[]
  approvalSteps      ApprovalStep[]
  paymentAdjustments PaymentAdjustment[]
  transactions       AccountTransaction[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("requests")
}

model RequestItem {
  id          String  @id @default(cuid())
  requestId   String
  request     Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  note        String?

  @@map("request_items")
}

model Attachment {
  id         String   @id @default(cuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  filename   String
  url        String
  mimeType   String
  size       Int
  data         Bytes?
  isSettlement Boolean  @default(false)
  isPayment    Boolean  @default(false)
  uploadedAt   DateTime @default(now())

  @@map("attachments")
}

model ApprovalStep {
  id        String           @id @default(cuid())
  requestId String
  request   Request          @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepOrder Int
  title     String
  records   ApprovalRecord[]

  @@unique([requestId, stepOrder])
  @@map("approval_steps")
}

model Notification {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  message          String
  type             NotificationType
  relatedRequestId String?
  isRead           Boolean          @default(false)
  readAt           DateTime?
  deliveryStatus   String           @default("IN_APP")
  createdAt        DateTime         @default(now())

  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("push_subscriptions")
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String
  userName    String
  action      AuditAction
  entityType  String
  entityId    String?
  description String
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model PaymentRecipient {
  id              String   @id @default(cuid())
  name            String
  bankName        String?
  bankCode        String?
  branchName      String?
  branchCode      String?
  bankAccountNumber String?
  paymentInfoNote String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("payment_recipients")
}

model AccountingSubject {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  direction String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  requests           Request[]           @relation("AccountingSubject")
  finalRequests      Request[]           @relation("FinalAccountingSubject")
  paymentAdjustments PaymentAdjustment[]
  transactions       AccountTransaction[]

  @@map("accounting_subjects")
}

model ApprovalRecord {
  id         String         @id @default(cuid())
  stepId     String
  step       ApprovalStep   @relation(fields: [stepId], references: [id], onDelete: Cascade)
  approverId String
  approver   User           @relation(fields: [approverId], references: [id])
  action     ApprovalAction
  comment    String?
  actedAt    DateTime       @default(now())

  @@map("approval_records")
}

model PaymentAdjustment {
  id                  String                @id @default(cuid())
  requestId           String
  request             Request               @relation(fields: [requestId], references: [id], onDelete: Cascade)
  type                PaymentAdjustmentType
  amount              Decimal               @db.Decimal(12, 2)
  accountingSubjectId String?
  accountingSubject   AccountingSubject?    @relation(fields: [accountingSubjectId], references: [id])
  occurredAt          DateTime
  note                String?
  createdById         String
  createdBy           User                  @relation("PaymentAdjustmentCreatedBy", fields: [createdById], references: [id])
  updatedById         String?
  updatedBy           User?                 @relation("PaymentAdjustmentUpdatedBy", fields: [updatedById], references: [id])
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@map("payment_adjustments")
}

model FinancialAccount {
  id              String               @id @default(cuid())
  name            String               @unique
  type            FinancialAccountType
  bankName        String?
  accountLastFive String?
  initialBalance  Decimal              @default(0) @db.Decimal(14, 2)
  isActive        Boolean              @default(true)
  note            String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  transactions    AccountTransaction[]

  @@map("financial_accounts")
}

model AccountTransaction {
  id                  String             @id @default(cuid())
  accountId           String
  account             FinancialAccount   @relation(fields: [accountId], references: [id])
  type                TransactionType
  amount              Decimal            @db.Decimal(14, 2)
  transactionDate     DateTime
  summary             String
  counterparty        String?
  projectId           String?
  project             Project?           @relation(fields: [projectId], references: [id])
  accountingSubjectId String?
  accountingSubject   AccountingSubject? @relation(fields: [accountingSubjectId], references: [id])
  requestId           String?
  request             Request?           @relation(fields: [requestId], references: [id])
  note                String?
  createdById         String
  createdBy           User               @relation("TransactionCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([accountId])
  @@index([transactionDate])
  @@index([projectId])
  @@map("account_transactions")
}
