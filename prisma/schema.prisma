generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PRESIDENT
  FOUNDER_AGENT
  FINANCE
  SECRETARY
  DIRECTOR
  SUPERVISOR
  APPLICANT
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  CLOSED
}

enum RequestType {
  REIMBURSEMENT
  PREPAID
}

enum RequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  RETURNED
  PAID
  CLOSED
}

enum ApprovalAction {
  APPROVED
  REJECTED
  RETURNED
}

model User {
  id           String           @id @default(cuid())
  name         String
  email        String           @unique
  passwordHash String
  role         UserRole         @default(DIRECTOR)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  requests     Request[]
  approvals    ApprovalRecord[]

  @@map("users")
}

model Project {
  id        String        @id @default(cuid())
  name      String        @unique
  status    ProjectStatus @default(IN_PROGRESS)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  requests  Request[]

  @@map("projects")
}

model Request {
  id             String         @id @default(cuid())
  requestNumber  String?        @unique
  type           RequestType
  status         RequestStatus  @default(DRAFT)
  title          String
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id])
  projectName    String?
  description    String?
  purpose        String?
  amount         Decimal        @db.Decimal(12, 2)
  currency       String         @default("TWD")
  requestDate    DateTime       @default(now())
  neededBy       DateTime?
  submittedAt    DateTime?
  paidAt             DateTime?
  paymentMethod      String?
  paymentReference   String?
  paymentNote        String?
  paidBy             String?
  bankName           String?
  bankCode           String?
  branchName         String?
  branchCode         String?
  recipientName      String?
  paymentInfoNote    String?
  submitterId    String
  submitter      User           @relation(fields: [submitterId], references: [id])
  items          RequestItem[]
  attachments    Attachment[]
  approvalSteps  ApprovalStep[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("requests")
}

model RequestItem {
  id          String  @id @default(cuid())
  requestId   String
  request     Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  note        String?

  @@map("request_items")
}

model Attachment {
  id         String   @id @default(cuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  filename   String
  url        String
  mimeType   String
  size       Int
  data       Bytes?
  uploadedAt DateTime @default(now())

  @@map("attachments")
}

model ApprovalStep {
  id        String           @id @default(cuid())
  requestId String
  request   Request          @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepOrder Int
  title     String
  records   ApprovalRecord[]

  @@unique([requestId, stepOrder])
  @@map("approval_steps")
}

model ApprovalRecord {
  id         String         @id @default(cuid())
  stepId     String
  step       ApprovalStep   @relation(fields: [stepId], references: [id], onDelete: Cascade)
  approverId String
  approver   User           @relation(fields: [approverId], references: [id])
  action     ApprovalAction
  comment    String?
  actedAt    DateTime       @default(now())

  @@map("approval_records")
}
